---
import type { CategoryConfig } from "../data/products";

interface Props { categories: CategoryConfig[]; }
const { categories } = Astro.props;

// Gaming → full width
const gaming = categories[0];
// Rest → pairs of 2, last one full if odd
const rest = categories.slice(1);
const pairs: CategoryConfig[][] = [];
for (let i = 0; i < rest.length; i += 2) {
  pairs.push(rest.slice(i, i + 2));
}
---

<div class="bands-wrapper">
<!-- GAMING — full width -->
<a href={`/categoria/${gaming.id}`} class="band band-full" style={`background:${gaming.color}`}>
  <div class="band-inner">
    <h2 class="band-title">{gaming.name}</h2>
    <p class="band-sub">{gaming.tagline}</p>
    <span class="band-cta">
      Ver productos
      <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
        <path fill-rule="evenodd" d="M7.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L11.586 10 7.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
    </span>
  </div>
  {gaming.image && (
    <div class="band-img">
      <img src={gaming.image} alt={gaming.name} />
    </div>
  )}
</a>

<!-- PAIRS — 2 per row -->
{pairs.map(pair => (
  <div class={`band-row ${pair.length === 1 ? "band-row-single" : ""}`}>
    {pair.map(cat => (
      <a href={`/categoria/${cat.id}`} class="band band-half" style={`background:${cat.color}`}>
        <div class="band-inner">
          <h2 class="band-title">{cat.name}</h2>
          <p class="band-sub">{cat.tagline}</p>
          <span class="band-cta">
            Ver productos
            <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
              <path fill-rule="evenodd" d="M7.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L11.586 10 7.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
          </span>
        </div>
        {cat.image && (
          <div class="band-img">
            <img src={cat.image} alt={cat.name} />
          </div>
        )}
      </a>
    ))}
  </div>
))}

</div>
<style>
  .bands-wrapper {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 12px;
    background: var(--bg);
  }

  /* ── SHARED ── */
  .band {
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: #1d1d1f;
    overflow: hidden;
    transition: filter 0.25s;
  }

  .band:hover { filter: brightness(0.96); }

  .band-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding: 52px 24px 0;
  }

  .band-title {
    font-weight: 800; letter-spacing: -2.5px; line-height: 1;
    color: #1d1d1f; margin-bottom: 12px;
  }

  .band-sub {
    font-size: 15px; font-weight: 300;
    color: #555; line-height: 1.5;
    margin-bottom: 26px;
  }

  .band-cta {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 11px 24px;
    background: #0071e3; color: white;
    border-radius: 980px; font-size: 13.5px; font-weight: 600;
    margin-bottom: 36px;
    transition: background 0.2s;
  }

  .band:hover .band-cta { background: #0077ed; }

  .band-img {
    width: 100%;
    display: flex; justify-content: center; align-items: flex-end;
    overflow: hidden;
  }

  .band-img img {
    width: auto; object-fit: contain; object-position: bottom;
    filter: drop-shadow(0 12px 36px rgba(0,0,0,0.13));
  }

  /* ── FULL WIDTH (Gaming) ── */
  .band-full {
    width: 100%;
    min-height: 460px;
  }

  .band-full .band-title { font-size: clamp(56px, 7vw, 88px); }
  .band-full .band-img { max-height: 260px; }
  .band-full .band-img img { height: 260px; }

  /* ── ROW WRAPPER ── */
  .band-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    gap: 12px;
  }

  /* Single item row (Otros) → full width */
  .band-row-single {
    grid-template-columns: 1fr;
  }

  /* ── HALF BANDS ── */
  .band-half {
    min-height: 400px;
  }

  .band-half .band-title { font-size: clamp(32px, 4vw, 56px); }
  .band-half .band-img { max-height: 220px; }
  .band-half .band-img img { height: 220px; }

  /* Single full-width half (Otros) */
  .band-row-single .band-half {
    min-height: 360px;
  }

  .band-row-single .band-half .band-title { font-size: clamp(40px, 5vw, 72px); }
  .band-row-single .band-half .band-img { max-height: 240px; }
  .band-row-single .band-half .band-img img { height: 240px; }

  /* ── RESPONSIVE ── */
  @media (max-width: 700px) {
    .band-row { grid-template-columns: 1fr; }
    .band-half { min-height: 340px; }
    .band-full { min-height: 380px; }
  }

  @keyframes floatImg {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-10px); }
  }

  .band-img img {
    animation: floatImg 4s ease-in-out infinite;
  }

</style>
