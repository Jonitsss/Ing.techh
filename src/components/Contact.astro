<style>
  .contact-section {
    background: #ffffff;
    padding: 80px 0;
    border-top: 1px solid #f0f0f0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  /* LEFT */
  .contact-title {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    letter-spacing: -1.5px;
    color: #1d1d1f;
    margin-bottom: 12px;
  }

  .contact-sub {
    font-size: 15px;
    color: #6e6e73;
    line-height: 1.6;
    margin-bottom: 36px;
  }

  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: #f9f9fb;
    border-radius: 14px;
    text-decoration: none;
    color: #1d1d1f;
    transition: background 0.2s, transform 0.2s;
  }

  .contact-item:hover { background: #f0f0f5; transform: translateX(4px); }

  .contact-icon {
    width: 48px; height: 48px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    color: white;
  }

  .wa-icon  { background: #25d366; }
  .ig-icon  { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
  .loc-icon { background: #0071e3; }
  .time-icon { background: #5172b0; }

  .contact-item-title { font-size: 14px; font-weight: 700; margin-bottom: 2px; }
  .contact-item-sub   { font-size: 13px; color: #6e6e73; }

  /* RIGHT CTA CARD */
  .contact-cta-wrap {
    display: flex;
    justify-content: center;
  }

  .contact-cta-card {
    background: linear-gradient(135deg, #ede8f5 0%, #dbeafe 100%);
    border-radius: 24px;
    padding: 48px 40px;
    text-align: center;
    max-width: 380px;
    width: 100%;
  }

  .cta-emoji { font-size: 48px; margin-bottom: 16px; }

  .cta-title {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.8px;
    color: #1d1d1f;
    margin-bottom: 10px;
  }

  .cta-sub {
    font-size: 14px;
    color: #555;
    line-height: 1.6;
    margin-bottom: 28px;
  }

  .cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 24px;
    background: #25d366;
    color: white;
    border-radius: 980px;
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 12px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }

  .cta-btn:hover { background: #1ebe5d; transform: scale(1.02); }

  .cta-btn-ig {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 13px 24px;
    background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: white;
    border-radius: 980px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }

  .cta-btn-ig:hover { opacity: 0.9; transform: scale(1.02); }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .contact-cta-card { padding: 36px 24px; }
  }
</style>
