---
import { getCategories } from "../data/sheets";
const categories = getCategories();
---

<footer>
  <div class="container">
    <div class="footer-top">

      <div class="footer-nav">
        <p class="footer-nav-title">Categorías</p>
        <ul>
          {categories.map((cat) => (
            <li><a href={`/categoria/${cat.id}`}>{cat.name}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Ing.Techh. Todos los derechos reservados.</p>
      <p>Los precios pueden variar sin previo aviso. Consultá disponibilidad.</p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--text-primary);
    color: rgba(255,255,255,0.7);
    padding: 64px 0 32px;
    margin-top: 80px;
  }

  .footer-top {
    display: flex;
    gap: 64px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .footer-nav { min-width: 180px; }

  .footer-nav-title {
    font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 16px;
  }

  .footer-nav ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }

  .footer-nav ul a { font-size: 14px; color: rgba(255,255,255,0.65); transition: color 0.2s; text-decoration: none; }
  .footer-nav ul a:hover { color: white; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 24px;
    display: flex; justify-content: space-between; flex-wrap: wrap;
    gap: 8px; font-size: 12px; color: rgba(255,255,255,0.35);
  }
</style>
