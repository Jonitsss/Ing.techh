---
import { categories } from "../data/products";
---

<footer>
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">Ing.<span>Techh</span></a>
        <p class="footer-desc">
          Tu tienda de tecnología de confianza.<br />
          Envíos a todo el país · Garantía en todos los productos.
        </p>
        <a
          href="https://wa.me/5491100000000"
          class="footer-wa"
          target="_blank"
          rel="noopener"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.28 7.044L.786 23.214l4.284-1.374A11.933 11.933 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.019-1.378l-.36-.214-3.728 1.195 1.214-3.636-.235-.374A9.818 9.818 0 012.182 12C2.182 6.58 6.58 2.182 12 2.182S21.818 6.58 21.818 12 17.42 21.818 12 21.818z"/>
          </svg>
          Escribinos por WhatsApp
        </a>
      </div>

      <div class="footer-nav">
        <p class="footer-nav-title">Categorías</p>
        <ul>
          {categories.map((cat) => (
            <li><a href={`#${cat.id}`}>{cat.name}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Ing.Techh. Todos los derechos reservados.</p>
      <p>Los precios pueden variar sin previo aviso. Consultá disponibilidad.</p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--text-primary);
    color: rgba(255,255,255,0.7);
    padding: 64px 0 32px;
    margin-top: 80px;
  }

  .footer-top {
    display: flex;
    gap: 64px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .footer-brand {
    flex: 1;
    min-width: 240px;
  }

  .footer-logo {
    font-size: 20px;
    font-weight: 800;
    color: white;
    letter-spacing: -0.5px;
    display: inline-block;
    margin-bottom: 14px;
  }

  .footer-logo span {
    color: var(--brand-light);
  }

  .footer-desc {
    font-size: 14px;
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .footer-wa {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: #25d366;
    color: white;
    border-radius: 980px;
    font-size: 13.5px;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .footer-wa:hover { opacity: 0.85; }

  .footer-nav { min-width: 180px; }

  .footer-nav-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 16px;
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-nav ul a {
    font-size: 14px;
    color: rgba(255,255,255,0.65);
    transition: color 0.2s;
  }

  .footer-nav ul a:hover { color: white; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 12px;
    color: rgba(255,255,255,0.35);
  }
</style>
