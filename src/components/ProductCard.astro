---
import type { Product } from "../data/sheets";
import { formatPrice } from "../data/sheets";

interface Props { product: Product; }
const { product } = Astro.props;

const isOferta = product.tags.includes("OFERTA");
const priceStr = formatPrice(product.price, product.currency);
---

<div class="product-card">
  <a href={`/producto/${product.id}`} class="product-card-link">
    <div class="product-img-wrap">
      {product.image
        ? <img src={product.image} alt={product.name} loading="lazy" />
        : <div class="product-img-placeholder">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="16" y="8" width="32" height="48" rx="4" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="32" cy="48" r="3" stroke="currentColor" stroke-width="1.5"/>
              <line x1="26" y1="12" x2="38" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
      }
      {isOferta && <span class="card-badge-oferta">Oferta</span>}
    </div>
    <div class="product-body">
      <p class="product-name">{product.name}</p>
      <p class="product-price">{priceStr}</p>
    </div>
  </a>
  <div class="product-footer">
    <a href={`/producto/${product.id}`} class="btn-detail">Ver detalle</a>
  </div>
</div>

<style>
  .product-card {
    background: #ffffff;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    display: flex; flex-direction: column;
  }
  .product-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,0,0,0.12); }
  .product-card-link { text-decoration: none; color: inherit; flex: 1; display: flex; flex-direction: column; }

  /* 4:3 ratio container */
  .product-img-wrap {
    background: #f5f5f7;
    aspect-ratio: 4 / 3;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.3s ease;
  }

  .product-card:hover .product-img-wrap img { transform: scale(1.04); }

  .product-img-placeholder { width: 56px; height: 56px; color: #c7c7cc; }
  .product-img-placeholder svg { width: 100%; height: 100%; }

  .card-badge-oferta {
    position: absolute; top: 10px; left: 10px;
    background: #ef4444; color: white;
    font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 3px 8px; border-radius: 20px;
  }

  .product-body { padding: 16px 18px 8px; flex: 1; display: flex; flex-direction: column; gap: 5px; }
  .product-name { font-size: 13.5px; font-weight: 500; line-height: 1.4; color: #1d1d1f; }
  .product-price { font-size: 15px; font-weight: 700; color: #0071e3; }

  .product-footer { padding: 10px 18px 18px; }
  .btn-detail {
    display: flex; align-items: center; justify-content: center;
    padding: 9px 14px; background: #0071e3; color: white;
    border-radius: 980px; font-size: 12.5px; font-weight: 600;
    text-decoration: none; width: 100%;
    transition: background 0.2s ease;
  }
  .btn-detail:hover { background: #0077ed; }
</style>
