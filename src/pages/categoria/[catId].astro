---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ProductCard from "../../components/ProductCard.astro";
import { categories, products } from "../../data/products";

export function getStaticPaths() {
  return categories.map(cat => ({
    params: { catId: cat.id },
    props: { cat },
  }));
}

const { cat } = Astro.props;
const catProducts = products.filter(p => p.category === cat.name);
const hasSubcats = cat.subcategories.length > 0;
const rootProducts = catProducts.filter(p => !p.subcategory);

const subcatData = cat.subcategories.map(sub => ({
  name: sub,
  products: catProducts.filter(p => p.subcategory === sub),
}));

// Soft palette for subcategory cards
const palette = [
  { bg: "#ede8f5", text: "#2d1f5e", accent: "#7c5cbf" },
  { bg: "#dbeafe", text: "#1e3a8a", accent: "#3b82f6" },
  { bg: "#d8f0e8", text: "#0e5c38", accent: "#10b981" },
  { bg: "#fef3c7", text: "#78350f", accent: "#f59e0b" },
  { bg: "#fce7f3", text: "#831843", accent: "#ec4899" },
  { bg: "#fde8d8", text: "#7a2e0e", accent: "#f97316" },
];
---

<Layout title={`${cat.name} — Ing.Techh`}>
  <Navbar />
  <main>

    <!-- HEADER BAND -->
    <div class="cat-header" style={`background:${cat.color}; color:${cat.textColor}`}>
      <div class="container">
        <nav class="breadcrumb">
          <a href="/">Inicio</a><span>›</span><span>{cat.name}</span>
        </nav>
        <div class="cat-header-inner">
          <div class="cat-header-text">
            <h1 class="cat-title">{cat.name}</h1>
            <p class="cat-tagline">{cat.tagline}</p>
          </div>
          {cat.image && (
            <div class="cat-header-img">
              <img src={cat.image} alt={cat.name} />
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- SUBCATEGORY CAROUSEL (Apple vertical cards) -->
    {hasSubcats && (
      <div class="subcat-section">
        <div class="container">
          <h2 class="section-title">Todas las categorías. <em>Elegí la tuya.</em></h2>
        </div>

        <div class="carousel-outer">
          <button class="carousel-arrow arrow-left" id="arrow-left" aria-label="Anterior">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="20" height="20">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>

          <div class="carousel-viewport" id="carousel-viewport">
            <div class="carousel-track" id="carousel-track">
              {subcatData.map((sub, i) => {
                const p = palette[i % palette.length];
                return (
                  <a
                    href={`/categoria/${cat.id}/${sub.name.toLowerCase().replace(/\s+/g,'-').replace(/[áàä]/g,'a').replace(/[éèë]/g,'e').replace(/[íìï]/g,'i').replace(/[óòö]/g,'o').replace(/[úùü]/g,'u').replace(/[^a-z0-9-]/g,'')}`}
                    class="subcat-card"
                    style={`background:${p.bg}; --txt:${p.text}; --accent:${p.accent}`}
                  >
                    <!-- top label -->
                    <div class="sc-top">
                      <span class="sc-category">{cat.name}</span>
                      <span class="sc-new" style={i === 0 ? "" : "display:none"}>Destacado</span>
                    </div>

                    <!-- name & count -->
                    <div class="sc-middle">
                      <h3 class="sc-name">{sub.name}</h3>
                      <p class="sc-count">{sub.products.length} productos disponibles</p>
                    </div>

                    <!-- sample product names preview -->
                    <div class="sc-preview">
                      {sub.products.slice(0, 3).map(p => (
                        <p class="sc-preview-item">— {p.name}</p>
                      ))}
                      {sub.products.length > 3 && (
                        <p class="sc-preview-more">+{sub.products.length - 3} más</p>
                      )}
                    </div>

                    <!-- cta -->
                    <div class="sc-bottom">
                      <span class="sc-cta">
                        Ver productos
                        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                          <path fill-rule="evenodd" d="M7.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L11.586 10 7.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                        </svg>
                      </span>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>

          <button class="carousel-arrow arrow-right" id="arrow-right" aria-label="Siguiente">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="20" height="20">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
        </div>

        <!-- Dots -->
        <div class="carousel-dots" id="carousel-dots">
          {subcatData.map((_, i) => (
            <button class={`dot ${i === 0 ? "active" : ""}`} data-i={i} aria-label={`Ir a ${i+1}`}></button>
          ))}
        </div>
      </div>
    )}

    <!-- ROOT PRODUCTS (no subcategory) -->
    {rootProducts.length > 0 && (
      <div class="container products-section">
        {hasSubcats && <h2 class="section-title" style="margin-top:0">Otros productos</h2>}
        <div class="products-grid">
          {rootProducts.map(p => <ProductCard product={p} />)}
        </div>
      </div>
    )}

  </main>
  <Footer />
</Layout>

<style>
  main { padding-top: var(--nav-h); }

  /* ── HEADER ── */
  .cat-header { padding: 52px 0 0; overflow: hidden; }

  .breadcrumb {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; opacity: 0.6; margin-bottom: 24px;
  }
  .breadcrumb a { text-decoration: none; color: inherit; }
  .breadcrumb a:hover { text-decoration: underline; }

  .cat-header-inner {
    display: flex; align-items: flex-end;
    justify-content: space-between; gap: 24px;
  }

  .cat-title {
    font-size: clamp(40px, 6vw, 68px);
    font-weight: 800; letter-spacing: -2.5px; line-height: 1; margin-bottom: 10px;
  }

  .cat-tagline { font-size: 16px; font-weight: 300; opacity: 0.7; padding-bottom: 44px; }

  .cat-header-img { height: 220px; flex-shrink: 0; display: flex; align-items: flex-end; }
  .cat-header-img img { height: 100%; width: auto; object-fit: contain; }

  /* ── SECTION TITLE ── */
  .subcat-section { padding: 64px 0 16px; }

  .section-title {
    font-size: 28px; font-weight: 700; letter-spacing: -0.8px;
    color: var(--text-primary); margin-bottom: 32px;
  }
  .section-title em { font-style: normal; color: var(--brand); }

  /* ── CAROUSEL ── */
  .carousel-outer {
    display: flex; align-items: center;
    gap: 16px; padding: 0 24px;
    max-width: 1200px; margin: 0 auto;
  }

  .carousel-viewport {
    flex: 1; overflow: hidden;
  }

  .carousel-track {
    display: flex; gap: 20px;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
    align-items: stretch;
  }

  /* ── SUBCATEGORY CARD — tall vertical Apple-style ── */
  .subcat-card {
    flex: 0 0 280px;
    min-height: 420px;
    border-radius: 22px;
    padding: 32px 28px 28px;
    display: flex; flex-direction: column;
    justify-content: space-between;
    text-decoration: none;
    color: var(--txt, #1d1d1f);
    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1), box-shadow 0.28s cubic-bezier(0.4,0,0.2,1);
    position: relative;
    overflow: hidden;
  }

  .subcat-card::after {
    content: '';
    position: absolute; inset: 0;
    background: rgba(0,0,0,0);
    transition: background 0.28s;
    border-radius: inherit;
  }

  .subcat-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 24px 60px rgba(0,0,0,0.13);
  }

  /* TOP */
  .sc-top {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 32px;
  }

  .sc-category {
    font-size: 11px; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    opacity: 0.45;
  }

  .sc-new {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.5px; text-transform: uppercase;
    color: var(--accent, var(--brand));
    background: rgba(255,255,255,0.6);
    padding: 3px 10px; border-radius: 20px;
  }

  /* MIDDLE */
  .sc-middle { flex: 1; }

  .sc-name {
    font-size: 26px; font-weight: 800;
    letter-spacing: -0.8px; line-height: 1.15;
    margin-bottom: 8px;
  }

  .sc-count {
    font-size: 13px; opacity: 0.55; margin-bottom: 24px;
  }

  /* PREVIEW */
  .sc-preview {
    display: flex; flex-direction: column; gap: 5px;
    margin-bottom: 24px;
  }

  .sc-preview-item {
    font-size: 12.5px; opacity: 0.6;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    line-height: 1.4;
  }

  .sc-preview-more {
    font-size: 12px; font-weight: 600;
    color: var(--accent, var(--brand));
    opacity: 0.8;
  }

  /* BOTTOM CTA */
  .sc-bottom { margin-top: auto; }

  .sc-cta {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 14px; font-weight: 700;
    color: var(--accent, var(--brand));
    transition: gap 0.2s;
  }

  .subcat-card:hover .sc-cta { gap: 10px; }

  /* ── ARROWS ── */
  .carousel-arrow {
    flex-shrink: 0; width: 44px; height: 44px;
    border-radius: 50%; border: 1.5px solid var(--border);
    background: white; cursor: pointer; color: var(--text-primary);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    transition: background var(--transition), box-shadow var(--transition);
  }
  .carousel-arrow:hover { background: var(--brand-subtle); color: var(--brand); }
  .carousel-arrow:disabled { opacity: 0.25; pointer-events: none; }

  /* ── DOTS ── */
  .carousel-dots {
    display: flex; justify-content: center; gap: 8px;
    margin-top: 28px;
  }

  .dot {
    width: 8px; height: 8px; border-radius: 50%;
    border: none; background: #d1d1d6; cursor: pointer; padding: 0;
    transition: background 0.2s, transform 0.2s;
  }
  .dot.active { background: var(--brand); transform: scale(1.35); }

  /* ── PRODUCTS ── */
  .products-section { padding: 56px 0 80px; }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
  }

  @media (max-width: 600px) {
    .products-grid { grid-template-columns: repeat(2,1fr); gap: 10px; }
    .subcat-card { flex: 0 0 260px; min-height: 380px; }
    .cat-header-img { display: none; }
    .carousel-arrow { display: none; }
  }
</style>

<script>
  const track = document.getElementById("carousel-track");
  const viewport = document.getElementById("carousel-viewport");
  const arrowLeft = document.getElementById("arrow-left") as HTMLButtonElement | null;
  const arrowRight = document.getElementById("arrow-right") as HTMLButtonElement | null;
  const dots = document.querySelectorAll<HTMLButtonElement>(".dot");

  if (track && viewport) {
    const cards = Array.from(track.querySelectorAll<HTMLElement>(".subcat-card"));
    const total = cards.length;
    let current = 0;

    function cardWidth() {
      return (cards[0]?.offsetWidth ?? 280) + 20; // card + gap
    }

    function getVisible() {
      return Math.max(1, Math.floor(viewport!.offsetWidth / cardWidth()));
    }

    function goTo(idx: number) {
      current = Math.max(0, Math.min(idx, total - getVisible()));
      track!.style.transform = `translateX(-${current * cardWidth()}px)`;
      dots.forEach((d, i) => d.classList.toggle("active", i === current));
      if (arrowLeft) arrowLeft.disabled = current === 0;
      if (arrowRight) arrowRight.disabled = current >= total - getVisible();
    }

    arrowLeft?.addEventListener("click", () => goTo(current - 1));
    arrowRight?.addEventListener("click", () => goTo(current + 1));
    dots.forEach((d, i) => d.addEventListener("click", () => goTo(i)));

    goTo(0);
  }
</script>
