---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import Footer from "../../../components/Footer.astro";
import ProductCard from "../../../components/ProductCard.astro";
import { fetchProducts, getCatBySlug, toSlug } from "../../../data/sheets";

const { catId, subcat } = Astro.params;
const cat = getCatBySlug(catId!);
if (!cat) return Astro.redirect("/");

// Find the real subcategory name from slug
const subName = cat.subcategories.find(s => toSlug(s) === subcat);
if (!subName) return Astro.redirect(`/categoria/${catId}`);

const allProducts = await fetchProducts();
const subProducts = allProducts.filter(p => p.category === cat.name && p.subcategory === subName);
---

<Layout title={`${subName} — ${cat.name} — Ing.Techh`}>
  <Navbar />
  <main>
    <div class="sub-header" style={`background:${cat.color}; color:${cat.textColor}`}>
      <div class="container">
        <nav class="breadcrumb">
          <a href="/">Inicio</a><span>›</span>
          <a href={`/categoria/${cat.id}`}>{cat.name}</a><span>›</span>
          <span>{subName}</span>
        </nav>
        <h1 class="sub-title">{subName}</h1>
        <p class="sub-count">{subProducts.length} productos disponibles</p>
      </div>
    </div>
    <div class="container page-body">
      <div class="products-grid">
        {subProducts.map(p => <ProductCard product={p} />)}
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  main { padding-top: var(--nav-h); }
  .sub-header { padding: 52px 0 44px; }
  .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 12px; opacity: 0.6; margin-bottom: 20px; }
  .breadcrumb a { text-decoration: none; color: inherit; }
  .breadcrumb a:hover { text-decoration: underline; }
  .sub-title { font-size: clamp(36px, 5vw, 56px); font-weight: 800; letter-spacing: -2px; line-height: 1; margin-bottom: 8px; }
  .sub-count { font-size: 15px; font-weight: 300; opacity: 0.6; }
  .page-body { padding: 48px 0 80px; }
  .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; }
  @media (max-width: 600px) { .products-grid { grid-template-columns: repeat(2,1fr); gap: 10px; } }
</style>
