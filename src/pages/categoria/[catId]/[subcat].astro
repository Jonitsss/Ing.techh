---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import Footer from "../../../components/Footer.astro";
import { fetchProducts, getCatBySlug, toSlug, formatPrice } from "../../../data/sheets";

const { catId, subcat } = Astro.params;
const cat = getCatBySlug(catId!);
if (!cat) return Astro.redirect("/");

const subName = cat.subcategories.find(s => toSlug(s) === subcat);
if (!subName) return Astro.redirect(`/categoria/${catId}`);

const allProducts = await fetchProducts();
const subProducts = allProducts.filter(p => p.category === cat.name && p.subcategory === subName);
const allTags = [...new Set(subProducts.flatMap(p => p.tags).filter(Boolean))];
---

<Layout title={`${subName} — ${cat.name} — Ing.Techh`}>
  <Navbar />
  <main>
    <div class="sub-header" style={`background:${cat.color}; color:${cat.textColor}`}>
      <div class="container">
        <nav class="breadcrumb">
          <a href="/">Inicio</a><span>›</span>
          <a href={`/categoria/${cat.id}`}>{cat.name}</a><span>›</span>
          <span>{subName}</span>
        </nav>
        <h1 class="sub-title">{subName}</h1>
        <p class="sub-count">{subProducts.length} productos disponibles</p>
      </div>
    </div>

    <div class="container page-body">
      <!-- FILTER BAR -->
      {allTags.length > 0 && (
        <div class="filter-bar" id="filter-bar">
          <button class="filter-btn active" data-filter="all">Todos</button>
          {allTags.map(tag => (
            <button class="filter-btn" data-filter={tag}>{tag}</button>
          ))}
        </div>
      )}

      <div class="products-grid" id="products-grid">
        {subProducts.map((p, i) => (
          <a
            href={`/producto/${p.id}`}
            class={`product-card ${i >= 8 ? 'hidden-product' : ''}`}
            data-tags={p.tags.join(',')}
          >
            <div class="product-img-wrap">
              {p.image
                ? <img src={p.image} alt={p.name} loading="lazy" />
                : <div class="product-img-placeholder">
                    <svg viewBox="0 0 64 64" fill="none" width="48" height="48">
                      <rect x="16" y="8" width="32" height="48" rx="4" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="32" cy="48" r="3" stroke="currentColor" stroke-width="1.5"/>
                    </svg>
                  </div>
              }
              {p.tags.includes('OFERTA') && <span class="badge-oferta">Oferta</span>}
            </div>
            <div class="product-info">
              <p class="product-name">{p.name}</p>
              <p class="product-price">
                {p.price ? (p.currency === 'USD' ? `USD ${p.price.toLocaleString('es-AR')}` : `$ ${p.price.toLocaleString('es-AR')}`) : 'Consultar precio'}
              </p>
              <span class="product-cta">Ver producto</span>
            </div>
          </a>
        ))}
      </div>

      {subProducts.length > 8 && (
        <div class="ver-mas-wrap" id="ver-mas-wrap">
          <button class="ver-mas-btn" id="ver-mas-btn">
            Ver más productos
            <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
          </button>
        </div>
      )}
    </div>
  </main>
  <Footer />
</Layout>

<style>
  main { padding-top: var(--nav-h); }
  .sub-header { padding: 52px 0 44px; }
  .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 12px; opacity: 0.6; margin-bottom: 20px; }
  .breadcrumb a { text-decoration: none; color: inherit; }
  .breadcrumb a:hover { text-decoration: underline; }
  .sub-title { font-size: clamp(36px, 5vw, 56px); font-weight: 800; letter-spacing: -2px; line-height: 1; margin-bottom: 8px; }
  .sub-count { font-size: 15px; font-weight: 300; opacity: 0.6; }
  .page-body { padding: 40px 0 80px; }

  .filter-bar { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 28px; }
  .filter-btn { padding: 7px 16px; border: 1.5px solid #e5e5ea; background: white; color: #1d1d1f; border-radius: 980px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: inherit; transition: all 0.2s; }
  .filter-btn:hover { border-color: #0071e3; color: #0071e3; }
  .filter-btn.active { background: #0071e3; color: white; border-color: #0071e3; }

  .products-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }

  .product-card { background: #fff; border-radius: 16px; overflow: hidden; text-decoration: none; color: #1d1d1f; box-shadow: 0 2px 8px rgba(0,0,0,0.06); transition: transform 0.25s, box-shadow 0.25s; display: flex; flex-direction: column; }
  .product-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.10); }
  .product-card.hidden-product { display: none; }

  .product-img-wrap { background: #f5f5f7; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative; }
  .product-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
  .product-card:hover .product-img-wrap img { transform: scale(1.04); }
  .product-img-placeholder { color: #c7c7cc; }
  .badge-oferta { position: absolute; top: 10px; left: 10px; background: #ef4444; color: white; font-size: 10px; font-weight: 700; text-transform: uppercase; padding: 3px 8px; border-radius: 20px; }

  .product-info { padding: 14px 16px 18px; flex: 1; display: flex; flex-direction: column; gap: 4px; }
  .product-name { font-size: 13.5px; font-weight: 500; line-height: 1.4; flex: 1; }
  .product-price { font-size: 15px; font-weight: 700; color: #0071e3; margin-top: 4px; }
  .product-cta { display: inline-flex; align-items: center; justify-content: center; margin-top: 10px; padding: 8px 16px; background: #0071e3; color: white; border-radius: 980px; font-size: 12.5px; font-weight: 600; transition: background 0.2s; }
  .product-card:hover .product-cta { background: #0077ed; }

  .ver-mas-wrap { display: flex; justify-content: center; margin-top: 32px; }
  .ver-mas-btn { display: inline-flex; align-items: center; gap: 8px; padding: 13px 32px; background: white; border: 1.5px solid #0071e3; color: #0071e3; border-radius: 980px; font-size: 15px; font-weight: 600; cursor: pointer; font-family: inherit; transition: all 0.2s; }
  .ver-mas-btn:hover { background: #0071e3; color: white; }

  @media (max-width: 1024px) { .products-grid { grid-template-columns: repeat(3,1fr); } }
  @media (max-width: 600px) { .products-grid { grid-template-columns: repeat(2,1fr); gap: 10px; } .product-info { padding: 10px 12px 14px; } }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const productCards = document.querySelectorAll<HTMLElement>(".product-card");
  const verMasWrap = document.getElementById("ver-mas-wrap");
  const verMasBtn = document.getElementById("ver-mas-btn");
  let activeFilter = "all";

  function applyFilter(filter: string) {
    activeFilter = filter;
    let visible = 0;
    productCards.forEach(card => {
      const tags = card.dataset.tags ?? "";
      const matches = filter === "all" || tags.split(",").includes(filter);
      if (matches) {
        visible++;
        card.style.display = visible <= 8 ? "" : "none";
        visible <= 8 ? card.classList.remove("hidden-product") : card.classList.add("hidden-product");
      } else {
        card.style.display = "none";
        card.classList.add("hidden-product");
      }
    });
    if (verMasWrap) verMasWrap.style.display = visible > 8 ? "flex" : "none";
  }

  filterBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      filterBtns.forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      applyFilter(btn.dataset.filter ?? "all");
    });
  });

  verMasBtn?.addEventListener("click", () => {
    productCards.forEach(card => {
      const tags = card.dataset.tags ?? "";
      if (activeFilter === "all" || tags.split(",").includes(activeFilter)) {
        card.style.display = "";
        card.classList.remove("hidden-product");
      }
    });
    if (verMasWrap) verMasWrap.style.display = "none";
  });

  applyFilter("all");
</script>
