---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import SmartphonesHero from "../components/SmartphonesHero.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import Reviews from "../components/Reviews.astro";
import TrustBar from "../components/TrustBar.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { getCategories, CATEGORY_CONFIG } from "../data/sheets";

const categories = getCategories();
const smartphones = CATEGORY_CONFIG["SmartPhones"];
const rest = categories.filter(c => c.id !== "smartphones");
---

<Layout
  title="Ing.Techh — iPhones, Gaming, Hogar y más | Zona Sur GBA"
  description="Comprá iPhones nuevos y usados, consolas, electrodomésticos y accesorios tech. Garantía en todos los productos. Envíos a todo el país. Zona sur GBA."
>
  <Navbar />
  <main>
    <SmartphonesHero cat={smartphones} />
    <CategoryGrid categories={rest} />
    <Reviews />
    <TrustBar />
    <Contact />
  </main>
  <Footer />
</Layout>

<style>
  main { padding-top: var(--nav-h); }
</style>
