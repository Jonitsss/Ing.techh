---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import SmartphonesHero from "../components/SmartphonesHero.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import Footer from "../components/Footer.astro";
import { categories } from "../data/products";

const smartphones = categories.find(c => c.id === "smartphones")!;
const rest = categories.filter(c => c.id !== "smartphones");
---

<Layout>
  <Navbar />
  <main>
    <SmartphonesHero cat={smartphones} />
    <CategoryGrid categories={rest} />
  </main>
  <Footer />
</Layout>

<style>
  main { padding-top: var(--nav-h); }
</style>
